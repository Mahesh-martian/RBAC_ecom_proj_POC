# ShopEase FastAPI backend — environment configuration
# Copy to .env and fill in real values.

# Server
PORT=5002
NODE_ENV=development

# Database (async PostgreSQL). For local Docker Postgres from the ecom stack:
#   postgresql+asyncpg://postgres:postgres@localhost:5432/shopease
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/shopease

# JWT
JWT_SECRET=change-me-access-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_TOKEN_SECRET=change-me-refresh-secret
JWT_REFRESH_TOKEN_EXPIRES_IN=30d
JWT_RESET_PASS_TOKEN=change-me-reset-secret
JWT_RESET_PASS_TOKEN_EXPIRES_IN=15m
RESET_PASS_LINK=http://localhost:3000/reset-password

# Cloudinary (image uploads)
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_SECRET=

# Email (Gmail app password via SMTP)
NODEMAILER_EMAIL=
NODEMAILER_APP_PASS=

# Stripe
STRIPE_SECRET_KEY=sk_test_...

# Seed admin
ADMIN_EMAIL=admin@shopease.com
ADMIN_PASSWORD=Admin1234

# Gemini (legacy chatbot fallback)
GEMINI_API_KEY=

# CORS
CORS_ORIGINS=http://localhost:3000,https://shop-ease-8a83-fe.vercel.app
